# Turso credentials. Create a DB with the Turso CLI, then copy these in.
#   turso db create rippner-approvals
#   turso db show rippner-approvals --url
#   turso db tokens create rippner-approvals
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-token-here

# Email notification on a new entry (Resend). Optional — if unset, sending is skipped.
# No domain verified, so `from` stays on resend.dev and Resend will only DELIVER
# to the email that owns the Resend account — put that address in NOTIFY_TO.
RESEND_API_KEY=re_your_key_here
NOTIFY_FROM=Rippner Approvals <onboarding@resend.dev>
NOTIFY_TO=your-resend-account-email@example.com
NOTIFY_REPLY_TO=info@rippnertennis.com

# Passcode that unlocks the "Manage list" (admin) tab so managers can add/remove
# pending players. If unset, the admin area stays locked for everyone.
ADMIN_PASSCODE=choose-a-shared-passcode
